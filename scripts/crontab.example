# Personal website: daily at 0:00 (midnight)
# 1. Install cron: sudo apt install -y cron && sudo systemctl enable cron && sudo systemctl start cron
# 2. Install: crontab -e  then paste the lines below (adjust PROJECT_DIR)
# 3. mkdir -p "$PROJECT_DIR/logs"
# 4. Backup 需目前使用者在 docker 群組: sudo usermod -aG docker $USER (登出再登入)
# 5. Git push 需可免密 push: 用 SSH key (ssh -T git@github.com 測試) 或 credential helper
# Manual run: ./scripts/run-cron-jobs.sh   or   ./scripts/run-cron-jobs.sh --no-clean

PROJECT_DIR=/home/ben/personal-website

# Single entry: backup + git add/commit/push (no sudo; run as your user)
0 0 * * * cd "$PROJECT_DIR" && ./scripts/run-cron-jobs.sh --no-clean >> "$PROJECT_DIR/logs/cron.log" 2>&1

# Clean build (optional, weekly)
# 0 0 * * 0 cd "$PROJECT_DIR" && ./scripts/clean-build.sh >> "$PROJECT_DIR/logs/clean-build.log" 2>&1
