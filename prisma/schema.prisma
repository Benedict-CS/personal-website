generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id                    String        @id @default(uuid())
  title                 String
  slug                  String        @unique
  content               String
  description           String?
  published             Boolean       @default(false)
  pinned                Boolean       @default(false)
  category              String?
  order                 Int           @default(0)
  previewToken          String?       @unique
  previewTokenExpiresAt DateTime?
  publishedAt           DateTime?
  viewCount             Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tags                  Tag[]
  versions              PostVersion[]

  @@index([category, order])
  @@index([category, createdAt])
  @@index([published, publishedAt])
  @@index([published, pinned, publishedAt])
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostVersion {
  id            String   @id @default(uuid())
  postId        String
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  title         String
  slug          String
  content       String
  published     Boolean
  tags          String
  createdAt     DateTime @default(now())
  versionNumber Int

  @@index([postId])
  @@index([postId, createdAt])
}

model AboutConfig {
  id                 String   @id @default(uuid())
  profileImage       String?
  heroName           String?
  heroTagline        String?
  heroPhone          String?
  heroEmail          String?
  heroPortfolioLabel String?
  heroPortfolioUrl   String?
  introText          String?
  aboutMainContent   String?
  educationBlocks    String   @default("[]")
  experienceBlocks   String   @default("[]")
  volunteerBlocks    String   @default("[]")
  projectBlocks      String   @default("[]")
  schoolLogos        String   @default("[]")
  projectImages      String   @default("[]")
  companyLogos       String   @default("[]")
  contactHeading     String?
  contactText        String?
  contactLinks       String   @default("[]")
  technicalSkills    String   @default("[]")
  achievements       String   @default("[]")
  customSections     String   @default("[]")
  sectionOrder       String   @default("[\"education\",\"experience\",\"volunteer\",\"projects\",\"skills\",\"achievements\"]")
  sectionVisibility  String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Singleton row id=1: site branding, meta, nav, contact routing.
model SiteConfig {
  id                   Int      @id @default(1)
  siteName             String   @default("My Site")
  logoUrl              String?
  faviconUrl           String?
  metaTitle            String   @default("")
  metaDescription      String?
  metaKeywords         String?
  authorName           String?
  links                Json     @default("{}")
  socialLinks          Json     @default("{}")
  navItems             Json     @default("[]")
  footerText           String?
  copyrightText        String?
  ogImageUrl           String?
  googleAnalyticsId    String?
  setupCompleted       Boolean  @default(false)
  templateId           String   @default("default")
  themeMode            String   @default("light")
  autoAddCustomPagesToNav Boolean @default(true)
  contactEmail         String?
  contactWebhookUrl    String?
  backupRsyncTarget    String?
  backupPostHookUrl    String?
  updatedAt            DateTime @updatedAt
}

model CustomPage {
  id        String   @id @default(uuid())
  slug      String   @unique
  title     String
  content   String
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, order])
}

model SitePageContent {
  id        String   @id @default(uuid())
  page      String   @unique
  content   Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(uuid())
  action       String
  resourceType String
  resourceId   String?
  details      String?
  ip           String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

model PageView {
  id              String   @id @default(uuid())
  path            String
  ip              String
  country         String?
  city            String?
  durationSeconds Int?
  referrer        String?  @db.VarChar(512)
  userAgent       String?  @db.VarChar(512)
  createdAt       DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([ip])
  @@index([country])
}

model AccessBlockLog {
  id        String   @id @default(uuid())
  ip        String
  path      String
  userAgent String?  @db.VarChar(512)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([ip])
}

model BuilderPage {
  id          String               @id @default(uuid())
  ownerKey    String
  siteScope   String               @default("default")
  slug        String
  title       String
  status      String               @default("draft")
  seoMetadata Json                 @default("{}")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  blocks      BuilderBlock[]
  versions    BuilderPageVersion[]

  @@unique([ownerKey, siteScope, slug])
  @@index([ownerKey, siteScope, updatedAt])
}

model BuilderBlock {
  id         String                @id @default(uuid())
  pageId     String
  page       BuilderPage           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type       String
  content    Json                  @default("{}")
  styling    Json                  @default("{}")
  order      Int                   @default(0)
  visibility String                @default("all")
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  versions   BuilderBlockVersion[]

  @@index([pageId, order])
}

model BuilderBlockVersion {
  id            String       @id @default(uuid())
  blockId       String
  block         BuilderBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  content       Json         @default("{}")
  styling       Json         @default("{}")
  versionNumber Int
  createdBy     String?
  createdAt     DateTime     @default(now())

  @@index([blockId, createdAt])
  @@index([blockId, versionNumber])
}

model BuilderPageVersion {
  id            String      @id @default(uuid())
  pageId        String
  page          BuilderPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  snapshot      Json        @default("{}")
  versionNumber Int
  createdBy     String?
  createdAt     DateTime    @default(now())

  @@index([pageId, createdAt])
  @@index([pageId, versionNumber])
}

model BuilderTemplate {
  id        String   @id @default(uuid())
  ownerKey  String
  siteScope String   @default("default")
  name      String
  theme     String   @default("clean")
  brand     Json     @default("{}")
  blocks    Json     @default("[]")
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerKey, siteScope, updatedAt])
  @@index([siteScope, isShared, updatedAt])
}

model BuilderComponent {
  id        String   @id @default(uuid())
  ownerKey  String
  siteScope String   @default("default")
  name      String
  block     Json     @default("{}")
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerKey, siteScope, updatedAt])
  @@index([siteScope, isShared, updatedAt])
}
