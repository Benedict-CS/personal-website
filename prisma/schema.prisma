generator client {
  provider = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String        @id @default(uuid())
  title       String
  slug        String        @unique
  content     String
  description String?       // Short abstract/summary for card display (not shown in article body)
  published   Boolean       @default(false)
  pinned      Boolean       @default(false)
  category    String?       // Category path, e.g. "LeetCode/Array", "System Design"
  order       Int           @default(0) // Order within category for manual sorting
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tags        Tag[]
  versions    PostVersion[]
  
  @@index([category, order])
  @@index([category, createdAt])
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PostVersion {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  title     String
  slug      String
  content   String
  published Boolean
  tags      String   // JSON string of tag names
  createdAt DateTime @default(now())
  versionNumber Int   // Version number for this post

  @@index([postId])
  @@index([postId, createdAt])
}

model AboutConfig {
  id            String   @id @default(uuid())
  profileImage  String?  // Profile photo URL
  introText        String?  // Optional intro/bio at top of About page
  aboutMainContent  String?  // Legacy: one markdown; use educationBlocks/experienceBlocks/projectBlocks instead
  educationBlocks   String   @default("[]") // [{title, logoUrl?, organization, dateRange, content}]
  experienceBlocks  String   @default("[]")
  projectBlocks     String   @default("[]")
  schoolLogos       String   @default("[]") // JSON array: [{school: "NYCU", logo: "url"}, ...]
  projectImages String   @default("[]") // JSON array: [{project: "project-name", image: "url"}, ...]
  companyLogos  String   @default("[]") // JSON array: [{company: "Company Name", logo: "url"}, ...]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([id])
}

// Editable content for Home and Contact (and optional About intro is in AboutConfig)
model SitePageContent {
  id        String   @id @default(uuid())
  page      String   @unique // "home" | "contact"
  content   Json     // page-specific fields
  updatedAt DateTime @updatedAt
}

// Analytics: page views for dashboard stats (exclude own IP via ANALYTICS_EXCLUDED_IPS)
model PageView {
  id             String   @id @default(uuid())
  path           String
  ip             String
  country        String?  // ISO country code from GeoIP
  city           String?  // City from GeoIP (when available)
  durationSeconds Int?    // time on page (set when user leaves)
  createdAt      DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@index([ip])
  @@index([country])
}
