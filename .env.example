# Required for docker compose: set these before "docker compose up" (no defaults in docker-compose.yml)
# Copy this file to .env and fill in real values. Never commit .env.

# Database Configuration
# Prisma / Next.js use DATABASE_URL. When running migrate on the host, set this.
# When using Docker, run migrate inside the app container: docker compose exec app npx prisma migrate deploy
# Optional for high traffic: add ?connection_limit=10 to DATABASE_URL (see docs/ENVIRONMENT.md)
DATABASE_URL=postgresql://ben:your-password@localhost:5432/blog
POSTGRES_USER=ben
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=blog

# RustFS Configuration
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=your-rustfs-password-here

# Optional: secret for POST /api/agents/marketing/cron and .../support/cron. If unset, those routes return 503.
# AGENT_CRON_SECRET=

# Next.js Application Secrets
ADMIN_PASSWORD=your-admin-password-here
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32
# Use your public URL here. Do NOT use localhost or 192.168.x.x — otherwise the browser will ask for "local network" permission.
NEXTAUTH_URL=https://benedict.winlab.tw
# NextAuth JWT/session lifetime in seconds (default 43200 = 12h). Min 300, max 2592000.
SESSION_MAX_AGE_SECONDS=43200
NEXT_PUBLIC_SITE_URL=https://benedict.winlab.tw

# Google Search Console HTML tag verification (meta tag content value only)
# GOOGLE_SITE_VERIFICATION=

# S3/RustFS Credentials
S3_ACCESS_KEY=your-s3-access-key-here
S3_SECRET_KEY=your-s3-secret-key-here
S3_BUCKET=uploads

# CV download filename for /api/cv/download (ASCII: letters, numbers, ._-). Default: Benedict_CV.pdf
# CV_DOWNLOAD_FILENAME=Benedict_CV.pdf

# Contact form — choose ONE:
#
# Option A: SMTP (for Gmail, use an App Password; regular account passwords will not work)
#   Go to Google Account -> Security -> 2-Step Verification -> App Passwords.
#   If App Password is unavailable (for example, managed school accounts), use Option B.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-full-email@gmail.com
# SMTP_PASS=16-character-app-password
# SMTP_FROM=Contact Form <your-full-email@gmail.com>
#
# Option B: Resend (no SMTP and no App Password required) - sign up at https://resend.com to get a free API key
# Never put real keys in .env.example or commit them to Git. Keep secrets only in local .env / .env.local.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
#
CONTACT_EMAIL=benedict.cs12@nycu.edu.tw
# Optional: CC/BCC for contact form (comma-separated)
# CONTACT_CC=team@example.com
# CONTACT_BCC=archive@example.com

# Login CAPTCHA (optional): after 2 failed attempts, Turnstile is required. Get keys at Cloudflare Turnstile.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Base URL for proxy→same-app fetch inside Docker (block log, page views). Default: request host. Docker: http://127.0.0.1:3000
INTERNAL_APP_ORIGIN=

# Optional: Redis (ioredis) for shared rate limits — contact form and failed login counters across multiple app instances.
# Recommended when running more than one app container (see docs/OPERATIONS_AND_RELIABILITY.md).
# Example: redis://localhost:6379  or  Upstash: rediss://default:token@host:6379
# REDIS_URL=

# Analytics (optional): page view logging for dashboard
# Set ANALYTICS_SECRET so middleware can call /api/analytics/view (e.g. openssl rand -hex 16)
ANALYTICS_SECRET=
# Optional: separate secret for logging blocked IPs (403). Defaults to ANALYTICS_SECRET if unset.
ACCESS_BLOCK_LOG_SECRET=
# Comma-separated IPs (or prefixes) to exclude from counts. Use trailing dot for subnet: 140.113. excludes 140.113.x.x
# Example: ANALYTICS_EXCLUDED_IPS=140.113.194.249,140.113.128.3,140.113.
ANALYTICS_EXCLUDED_IPS=

# IP block at the edge (optional). Prefix: trailing dot so 140.113.194. matches that /24 only.
# Default: 403 only on /dashboard, /editor, /auth, and most APIs — public /blog and / still work.
# Set ACCESS_BLOCK_PUBLIC=1 to 403 blocked IPs on all routes (full site ban; no analytics views).
# ACCESS_ALLOW_IPS = exact IPs always allowed even if they match a block prefix (your own IP).
# ACCESS_BLOCK_IP_PREFIXES=140.113.194.
# ACCESS_BLOCK_PUBLIC=1
# ACCESS_ALLOW_IPS=140.113.194.249

# Blog comments (Giscus, optional): get IDs from https://giscus.app
# NEXT_PUBLIC_GISCUS_REPO=owner/repo
# NEXT_PUBLIC_GISCUS_REPO_ID=
# NEXT_PUBLIC_GISCUS_CATEGORY=Comments
# NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Error reporting (Sentry, optional)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# Strict-Transport-Security (HSTS). Set true only when the site is always HTTPS (production).
# Applies to next.config.ts headers and to middleware (src/proxy.ts) when x-forwarded-proto is https.
# ENABLE_HSTS=true

# RFC 9116 security.txt (GET /.well-known/security.txt)
# SECURITY_TXT_CONTACT=mailto:security@example.com
# SECURITY_TXT_POLICY=https://example.com/security-policy

# Release label in GET /api/health (`appVersion`). Docker Compose defaults to "local".
# APP_VERSION=1.0.0
# Short git SHA alternative (truncated in JSON if long):
# GIT_COMMIT=abc123def456
#
# Docker build for the app image: 0 = webpack (default; OpenResty-safe static chunk URLs). 1 = Turbopack.
# NEXT_USE_TURBOPACK=0
#
# Published host port for the app container (inside container stays 3000). Use if host :3000 is already in use; point OpenResty at this port.
# APP_HOST_PORT=3000

# Post-deploy smoke test (no env vars): ./scripts/verify-health.sh — requires curl and Python 3 for JSON checks.

# Optional: SaaS multi-tenant edge routing (`src/app/api/infra/edge`). Middleware sends this secret when calling the edge API.
# EDGE_CONTROL_SECRET=

# --- Phase 5: SaaS billing (Stripe / Lemon Squeezy) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=
# STRIPE_PRICE_ID_BUSINESS=
# STRIPE_PRICE_ID_ENTERPRISE=
# LEMON_SQUEEZY_WEBHOOK_SECRET=
# LEMON_SQUEEZY_VARIANT_ID_PRO=
# LEMON_SQUEEZY_VARIANT_ID_BUSINESS=
# LEMON_SQUEEZY_VARIANT_ID_ENTERPRISE=
# LEMON_SQUEEZY_CHECKOUT_BASE_URL=https://your-store.lemonsqueezy.com
