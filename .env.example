# Required for docker compose: set these before "docker compose up" (no defaults in docker-compose.yml)
# Copy this file to .env and fill in real values. Never commit .env.

# Database Configuration
# Prisma / Next.js use DATABASE_URL. When running migrate on the host, set this.
# When using Docker, run migrate inside the app container: docker compose exec app npx prisma migrate deploy
# Optional for high traffic: add ?connection_limit=10 to DATABASE_URL (see docs/ENVIRONMENT.md)
DATABASE_URL=postgresql://ben:your-password@localhost:5432/blog
POSTGRES_USER=ben
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=blog

# RustFS Configuration
RUSTFS_ROOT_USER=rustfsadmin
RUSTFS_ROOT_PASSWORD=your-rustfs-password-here

# Next.js Application Secrets
ADMIN_PASSWORD=your-admin-password-here
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32
# Use your public URL here. Do NOT use localhost or 192.168.x.x — otherwise the browser will ask for "local network" permission.
NEXTAUTH_URL=https://benedict.winlab.tw
NEXT_PUBLIC_SITE_URL=https://benedict.winlab.tw

# S3/RustFS Credentials
S3_ACCESS_KEY=your-s3-access-key-here
S3_SECRET_KEY=your-s3-secret-key-here
S3_BUCKET=uploads

# Contact form — choose ONE:
#
# Option A: SMTP (Gmail 必須用「應用程式密碼」，不能用一般密碼)
#   到 Google 帳戶 → 安全性 → 兩步驟驗證 → 應用程式密碼。若拿不到（如學校帳號），改用 Option B。
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=你的完整信箱@gmail.com
# SMTP_PASS=16碼應用程式密碼
# SMTP_FROM=Contact Form <你的完整信箱@gmail.com>
#
# Option B: Resend（不用 SMTP、不用應用程式密碼）— 到 https://resend.com 註冊免費拿 API key
# 請勿把真實 key 寫進 .env.example 或提交到 Git。只放在本機 .env 或 .env.local。
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
#
CONTACT_EMAIL=benedict.cs12@nycu.edu.tw
# Optional: CC/BCC for contact form (comma-separated)
# CONTACT_CC=team@example.com
# CONTACT_BCC=archive@example.com

# Login CAPTCHA (optional): after 2 failed attempts, Turnstile is required. Get keys at Cloudflare Turnstile.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Analytics (optional): page view logging for dashboard
# Set ANALYTICS_SECRET so middleware can call /api/analytics/view (e.g. openssl rand -hex 16)
ANALYTICS_SECRET=
# Comma-separated IPs (or prefixes) to exclude from counts. Use trailing dot for subnet: 140.113. excludes 140.113.x.x
# Example: ANALYTICS_EXCLUDED_IPS=140.113.194.249,140.113.128.3,140.113.
ANALYTICS_EXCLUDED_IPS=

# Blog comments (Giscus, optional): get IDs from https://giscus.app
# NEXT_PUBLIC_GISCUS_REPO=owner/repo
# NEXT_PUBLIC_GISCUS_REPO_ID=
# NEXT_PUBLIC_GISCUS_CATEGORY=Comments
# NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Error reporting (Sentry, optional)
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
